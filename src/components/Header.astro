---
import { siteConfig } from '../config';
---

<header class="bg-white border-b border-gray-200">
  <div class="max-w-5xl mx-auto px-4 py-4 flex items-center justify-between">
    <a href="/" class="flex items-center gap-2 text-xl font-heading font-bold text-gray-900 hover:text-primary transition-colors">
      {siteConfig.logo && <img src={siteConfig.logo} alt={siteConfig.name} class="h-8" />}
      <span>{siteConfig.name}</span>
    </a>
    <nav class="hidden md:flex gap-6">
      {siteConfig.nav.map((item) => (
        <a
          href={item.href}
          class="text-gray-600 hover:text-primary transition-colors font-medium"
        >
          {item.label}
        </a>
      ))}
    </nav>
    <!-- Mobile menu button -->
    <button id="mobile-menu-btn" class="md:hidden p-2" aria-label="Menu">
      <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
      </svg>
    </button>
  </div>
  <!-- Mobile menu -->
  <nav id="mobile-menu" class="hidden md:hidden border-t border-gray-200 px-4 py-2">
    {siteConfig.nav.map((item) => (
      <a
        href={item.href}
        class="block py-2 text-gray-600 hover:text-primary transition-colors"
      >
        {item.label}
      </a>
    ))}
  </nav>
</header>

<script>
  const btn = document.getElementById('mobile-menu-btn');
  const menu = document.getElementById('mobile-menu');
  btn?.addEventListener('click', () => menu?.classList.toggle('hidden'));
</script>
