---
import { siteConfig } from '../config';
import { getCollection } from 'astro:content';

const pages = await getCollection('pages');
---

<header class="bg-white border-b border-gray-200">
  <div class="max-w-5xl mx-auto px-4 py-4 flex items-center justify-between">
    <a href="/" class="flex items-center gap-2 text-xl font-heading font-bold text-gray-900 hover:text-primary transition-colors">
      {siteConfig.logo && <img src={siteConfig.logo} alt={siteConfig.name} class="h-8" />}
      <span>{siteConfig.name}</span>
    </a>
    <nav class="hidden md:flex items-center gap-6">
      <a href="/" class="text-gray-600 hover:text-primary transition-colors font-medium">Home</a>
      <a href="/blog" class="text-gray-600 hover:text-primary transition-colors font-medium">Blog</a>
      {pages.length > 0 && (
        <div class="relative" id="info-dropdown">
          <button id="info-btn" class="text-gray-600 hover:text-primary transition-colors font-medium flex items-center gap-1">
            Info
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
            </svg>
          </button>
          <div id="info-menu" class="hidden absolute top-full left-0 mt-2 w-56 bg-white border border-gray-200 rounded-lg shadow-lg z-50 max-h-80 overflow-y-auto">
            {pages.map((page) => (
              <a href={`/${page.slug}/`} class="block px-4 py-2 text-sm text-gray-700 hover:bg-gray-50 hover:text-primary transition-colors">
                {page.data.title}
              </a>
            ))}
          </div>
        </div>
      )}
      <a href="/contact" class="text-gray-600 hover:text-primary transition-colors font-medium">Contact</a>
    </nav>
    <!-- Mobile menu button -->
    <button id="mobile-menu-btn" class="md:hidden p-2" aria-label="Menu">
      <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
      </svg>
    </button>
  </div>
  <!-- Mobile menu -->
  <nav id="mobile-menu" class="hidden md:hidden border-t border-gray-200 px-4 py-2">
    <a href="/" class="block py-2 text-gray-600 hover:text-primary transition-colors font-medium">Home</a>
    <a href="/blog" class="block py-2 text-gray-600 hover:text-primary transition-colors font-medium">Blog</a>
    {pages.length > 0 && (
      <div class="py-2">
        <p class="text-xs font-semibold text-gray-400 uppercase tracking-wide mb-1">Info</p>
        {pages.map((page) => (
          <a href={`/${page.slug}/`} class="block py-1.5 pl-3 text-sm text-gray-600 hover:text-primary transition-colors">
            {page.data.title}
          </a>
        ))}
      </div>
    )}
    <a href="/contact" class="block py-2 text-gray-600 hover:text-primary transition-colors font-medium">Contact</a>
  </nav>
</header>

<script>
  const mobileBtn = document.getElementById('mobile-menu-btn');
  const mobileMenu = document.getElementById('mobile-menu');
  mobileBtn?.addEventListener('click', () => mobileMenu?.classList.toggle('hidden'));

  const infoBtn = document.getElementById('info-btn');
  const infoMenu = document.getElementById('info-menu');
  infoBtn?.addEventListener('click', (e) => {
    e.stopPropagation();
    infoMenu?.classList.toggle('hidden');
  });
  document.addEventListener('click', () => infoMenu?.classList.add('hidden'));
</script>
